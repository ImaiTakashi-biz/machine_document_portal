APP_NAME=Machine Document Portal
APP_ENV=development
DEBUG=false
USE_SAMPLE_DATA=true
PERSISTENCE_MODE=memory

# PERSISTENCE_MODE=memory の間は、以下のPostgreSQL設定は使用されません。
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/machine_document_portal
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT=10

GOOGLE_CREDENTIALS_PATH=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SPREADSHEET_SHEET_NAME=生産中
GOOGLE_SPREADSHEET_START_ROW=2
GOOGLE_SPREADSHEET_MACHINE_COLUMN=D
GOOGLE_SPREADSHEET_PART_NUMBER_COLUMN=H
GOOGLE_SPREADSHEET_PRODUCT_NAME_COLUMN=I
GOOGLE_SPREADSHEET_STATUS_COLUMN=A
GOOGLE_SPREADSHEET_ACTIVE_STATUS=稼働中
NAS_DRAWING_DIRECTORY=

# SharePoint / Notion連携
# DRIVE_ID・FOLDER_ID: H列の品番とファイル名（拡張子除く）を完全一致で検索
# *_URL: サイドバーの外部リンク（空欄は非表示）
# MICROSOFT_*: Graph認証用。Sites.Selected＋対象サイトのRead権限が必要
SHAREPOINT_DRIVE_ID=
SHAREPOINT_FOLDER_ID=
SHAREPOINT_PROCESS_INSPECTION_URL=
SHAREPOINT_SHIPPING_INSPECTION_URL=
NOTION_MEASUREMENT_EQUIPMENT_INSPECTION_URL=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# 翌営業日セット内容の13:00確認・ARAICHAT通知・15:00印刷
# 誤通知・誤印刷防止のため、設定確認後に true へ変更してください。
SCHEDULED_OPERATIONS_ENABLED=false
NEXT_DAY_SHEET_LOOKAHEAD_DAYS=31
ARAICHAT_BASE_URL=
ARAICHAT_API_KEY=
ARAICHAT_ROOM_ID=24
DRAWING_PRINTER_NAME=iR-ADV C5735(第1工場)
DRAWING_PRINTER_DISPLAY_NAME=第1工場プリンター
# 印刷できなかった場合の自動再実行間隔（秒）。既定は3分後、5分後、10分後。
PRINT_RETRY_DELAYS_SECONDS=180,300,600
DASHBOARD_SNAPSHOT_PATH=data/dashboard_snapshot.json
SCHEDULED_JOB_STATE_PATH=data/scheduled_job_state.json

# Google Sheets取得間隔（秒）。品番が新規・変更された号機だけSharePoint/NASを再検索。0で停止。
AUTO_REFRESH_SECONDS=3600
# SharePoint/NASの全資料更新時刻（日本時間、HH:MM、カンマ区切り。空欄で無効）
# 例: DOCUMENT_REFRESH_TIMES=10:30,14:30
DOCUMENT_REFRESH_TIMES=
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
